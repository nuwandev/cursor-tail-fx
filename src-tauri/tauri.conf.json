{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cursora",
  "version": "1.0.0",
  "identifier": "com.nuwandev.cursora",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "url": "src/windows/overlay/index.html",
        "title": "Cursora",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyMUI1QTkyODlGRjAzMzgK\nUldRNEEvK0prbG9iNGhQcjY5eXdPNlFvaVNBR3JFdG0xRXJ5NmNPaUl6VjdaWUZuYmY1dnpzUWoK",
      "endpoints": [
        "https://github.com/nuwandev/cursor-tail-fx/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
